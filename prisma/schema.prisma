generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderType {
  EXPORT
  IMPORT
}

enum OrderStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  TT
  LC
  DA
  DP
  OA
}

enum TransportMode {
  ROAD
  RAIL
  SEA
  AIR
}

enum Currency {
  USD
  CNY
  VND
}

enum PartnerType {
  BUYER
  SUPPLIER
  FREIGHT_FORWARDER
  CUSTOMS_BROKER
  INSPECTION_AGENCY
  OTHER
}

enum PartnerCountry {
  VN
  CN
  OTHER
}

enum DocType {
  INVOICE
  PACKING_LIST
  CERTIFICATE_OF_ORIGIN
  CUSTOMS_DECLARATION
  QUARANTINE_CERT
  BL_AWB
  QUALITY_CERT
  TAX_PAYMENT_RECEIPT
  SPECIALIZED_INSPECTION
  PHYTOSANITARY_CERT
  FUMIGATION_CERT
  PAYMENT_CONFIRMATION
  OTHER
}

enum DocStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum FinancialType {
  IMPORT_TAX
  VAT
  CUSTOMS_FEE
  INSPECTION_FEE
  FREIGHT
  INSURANCE
  PAYMENT_RECEIVED
  PAYMENT_SENT
  OTHER
}

enum AlertType {
  STAGE_OVERDUE
  DOCUMENT_MISSING
  PAYMENT_DUE
  INSPECTION_EXPIRY
  CUSTOM_ALERT
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders    Order[]
  stageLogs StageLog[]

  @@map("users")
}

model Partner {
  id            String         @id @default(cuid())
  name          String
  type          PartnerType
  country       PartnerCountry @default(VN)
  contactPerson String?
  phone         String?
  email         String?
  taxCode       String?
  licenseNumber String?
  rating        Int?           @db.SmallInt
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  contractsBuyer  Contract[]     @relation("BuyerContracts")
  contractsSeller Contract[]     @relation("SellerContracts")
  orderPartners   OrderPartner[]

  @@map("partners")
}

model Contract {
  id             String        @id @default(cuid())
  contractNumber String        @unique
  type           OrderType
  buyerId        String
  sellerId       String
  buyer          Partner       @relation("BuyerContracts", fields: [buyerId], references: [id])
  seller         Partner       @relation("SellerContracts", fields: [sellerId], references: [id])
  signedDate     DateTime      @db.Date
  paymentMethod  PaymentMethod
  paymentTerms   String?
  paymentDueDays Int?
  totalValue     Decimal       @db.Decimal(18, 2)
  currency       Currency      @default(USD)
  fileUrl        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  orders Order[]

  @@map("contracts")
}

model Order {
  id                 String         @id @default(cuid())
  orderCode          String         @unique
  type               OrderType
  pipelineStage      Int            @default(1) @db.SmallInt
  stageEnteredAt     DateTime       @default(now())
  stageDeadline      DateTime?
  status             OrderStatus    @default(ACTIVE)
  contractId         String?
  contract           Contract?      @relation(fields: [contractId], references: [id])
  productDescription String
  hsCode             String?
  quantity           Decimal?       @db.Decimal(12, 3)
  unit               String?
  totalValue         Decimal?       @db.Decimal(18, 2)
  currency           Currency       @default(USD)
  incoterms          String?
  borderGate         String?
  transportMode      TransportMode?
  notes              String?
  createdById        String
  createdBy          User           @relation(fields: [createdById], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  documents  Document[]
  financials Financial[]
  stageLogs  StageLog[]
  alerts     Alert[]
  partners   OrderPartner[]

  @@map("orders")
}

model OrderPartner {
  id        String      @id @default(cuid())
  orderId   String
  partnerId String
  role      PartnerType
  order     Order       @relation(fields: [orderId], references: [id])
  partner   Partner     @relation(fields: [partnerId], references: [id])

  @@unique([orderId, partnerId, role])
  @@map("order_partners")
}

model Document {
  id         String    @id @default(cuid())
  orderId    String
  order      Order     @relation(fields: [orderId], references: [id])
  docType    DocType
  docNumber  String?
  issuedBy   String?
  issuedDate DateTime? @db.Date
  expiryDate DateTime? @db.Date
  fileUrl    String?
  fileKey    String?
  status     DocStatus @default(PENDING)
  notes      String?
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("documents")
}

model Financial {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id])
  type         FinancialType
  amount       Decimal       @db.Decimal(18, 2)
  currency     Currency
  exchangeRate Decimal?      @db.Decimal(10, 4)
  amountVnd    Decimal?      @db.Decimal(18, 2)
  paidAt       DateTime?     @db.Date
  paymentRef   String?
  notes        String?
  createdAt    DateTime      @default(now())

  @@map("financials")
}

model StageLog {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  fromStage   Int      @db.SmallInt
  toStage     Int      @db.SmallInt
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id])
  changedAt   DateTime @default(now())
  notes       String?

  @@map("stage_logs")
}

model Alert {
  id        String        @id @default(cuid())
  orderId   String?
  order     Order?        @relation(fields: [orderId], references: [id])
  alertType AlertType
  severity  AlertSeverity @default(WARNING)
  message   String
  isRead    Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@map("alerts")
}

model SLAConfig {
  id           String    @id @default(cuid())
  orderType    OrderType
  stage        Int       @db.SmallInt
  targetHours  Int
  warningHours Int

  @@unique([orderType, stage])
  @@map("sla_configs")
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  Currency
  rateToVnd Decimal  @db.Decimal(10, 2)
  date      DateTime @db.Date
  source    String?

  @@unique([currency, date])
  @@map("exchange_rates")
}
